{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "strict": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"],
      "@pi/core": ["../core/dist/index"]
    },
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "src/app/**/*",
    "src/components/**/*",
    "src/hooks/**/*",
    "src/lib/**/*",
    "src/providers/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
